  m_Material: {fileID: 0}
  m_Color: {r: 1, g: 1, b: 1, a: 1}
  m_RaycastTarget: 1
  m_RaycastPadding: {x: 0, y: 0, z: 0, w: 0}
  m_Maskable: 1
  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: "Diese Maschine ist eine Anomalie.\r\n\r\nAndere Maschinen reagieren berechenbar:
    Entweder sie ignorieren alles, was nicht in ihre Kategorien passt, oder sie gehen
    sofort in Konfrontation \xFCber. Diese Einheit jedoch beobachtet ihre Umgebung
    und weicht bei Gefahren aus. Sie ver\xE4ndert ihre Route, als w\xFCrde sie etwas
    erkennen, das in ihren Daten eigentlich keinen Platz haben d\xFCrfte. Ihr Aufbau
    ist unscheinbar. Eine kleine Kettenplattform mit einfachen Greifarmen, gebaut
    zum Sammeln von M\xFCllresten. Ihr fast schon klobiges Design l\xE4sst vermuten,
    dass es sich hier um einen Prototypen handelt. Da dieser Maschine nie eine offizielle
    Designierung zugeteilt wurde, gibt es keine klar aufzufindbaren Daten. \r\n\r\nTrotzdem
    spricht ihr Verhalten total gegen das etablierte Chaos in der neuen Welt. Es
    ist schwer zu sagen, ob hier ein Fehler vorliegt oder etwas anderes. Etwas, das
    nicht vollst\xE4ndig gel\xF6scht wurde. Als w\xFCrde sie nicht nur auf die Welt
    reagieren, sondern auf etwas, das nur sie noch wahrnimmt."
  m_isRightToLeft: 0
  m_fontAsset: {fileID: 11400000, guid: 8f586378b4e144a9851e7b34d9b748ee, type: 2}
